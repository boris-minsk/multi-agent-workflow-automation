# Copy to .env (gitignored) and adjust. Docker Compose reads .env automatically.

# Base URL the n8n workflow's HTTP nodes call (exposed to expressions as $env.API_BASE_URL).
#
# DEV (default): the API runs on the HOST via `dotnet run`. The n8n container
# reaches it through the Docker host gateway. The host API must listen on all
# interfaces (PowerShell: $env:ASPNETCORE_URLS="http://+:5032"), not just localhost.
API_BASE_URL=http://host.docker.internal:5032
#
# FULL profile (API also containerized): reach it by Compose service name instead.
# API_BASE_URL=http://api:8080

# Timezone for the schedule trigger (IANA name, e.g. Europe/Minsk).
TZ=UTC

# Only needed if you switch the containerized API to real providers (see docker-compose.yml).
# OPENAI_API_KEY=sk-...
# HUBSPOT_ACCESS_TOKEN=pat-...
